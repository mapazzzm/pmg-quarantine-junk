#!/usr/bin/perl
# pmg-quarantine-gen-ticket — генерирует авто-авторизационную ссылку на карантин PMG.
# Использует тот же механизм, что и встроенные отчёты PMG (RSA-тикет).
#
# Использование: pmg-quarantine-gen-ticket <pmail>
# Вывод: https://pmg.hostname:8006/quarantine?ticket=...

use strict;
use warnings;

use PMG::Ticket;
use PMG::Config;
use URI::Escape;

my $pmail = $ARGV[0] or die "Usage: $0 <pmail>\n";

my $ticket   = PMG::Ticket::assemble_quarantine_ticket($pmail);
my $esc      = uri_escape($ticket);

my $cfg      = PMG::Config->new();
my $hostname = $cfg->get('spamquar', 'hostname') // do {
    use PVE::INotify;
    PVE::Tools::get_fqdn(PVE::INotify::nodename());
};
my $port  = $cfg->get('spamquar', 'port')     // 8006;
my $proto = $cfg->get('spamquar', 'protocol') // 'https';

# Убираем порт из URL если он стандартный
my $port_suffix = '';
if ( ($proto eq 'https' && $port != 443) || ($proto eq 'http' && $port != 80) ) {
    $port_suffix = ":$port";
}

print "${proto}://${hostname}${port_suffix}/quarantine?ticket=${esc}\n";

#!/usr/bin/perl -T
# pmg-quarantine-gen-ticket — генерирует авто-авторизационную ссылку на карантин PMG.
# Использует тот же механизм, что и встроенные отчёты PMG (RSA-тикет).
#
# Использование: pmg-quarantine-gen-ticket <pmail>
# Вывод: https://pmg.hostname:8006/quarantine?ticket=...

use strict;
use warnings;

# Taint mode: очищаем окружение до загрузки модулей
BEGIN {
    $ENV{PATH} = '/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin';
    delete @ENV{qw(IFS CDPATH ENV BASH_ENV)};
}

use PMG::Ticket;
use PMG::Config;
use URI::Escape;

my $raw_pmail = $ARGV[0] or die "Usage: $0 <pmail>\n";

# Валидация и untaint: захваченная группа снимает taint
my ($pmail) = $raw_pmail =~ /\A([^@\s]+\@[^@\s]+\.[^@\s]+)\z/
    or die "Invalid email address: $raw_pmail\n";

my $ticket = eval { PMG::Ticket::assemble_quarantine_ticket($pmail) };
die "Failed to generate ticket: $@\n" if $@;
die "Empty ticket returned for $pmail\n" unless defined($ticket) && length($ticket);

my $esc = uri_escape($ticket);

my $cfg      = PMG::Config->new();
my $hostname = $cfg->get('spamquar', 'hostname') // do {
    use PVE::INotify;
    PVE::Tools::get_fqdn(PVE::INotify::nodename());
};
my $port  = $cfg->get('spamquar', 'port')     // 8006;
my $proto = $cfg->get('spamquar', 'protocol') // 'https';

# Убираем порт из URL если он стандартный
my $port_suffix = '';
if ( ($proto eq 'https' && $port != 443) || ($proto eq 'http' && $port != 80) ) {
    $port_suffix = ":$port";
}

print "${proto}://${hostname}${port_suffix}/quarantine?ticket=${esc}\n";

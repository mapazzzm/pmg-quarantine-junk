#!/usr/bin/env python3
"""
pmg-quarantine-notifier — сканирует карантин PMG, отправляет уведомления
с кнопками "Не спам" / "Спам" на почту пользователей (во Входящие).

Запускается по cron (рекомендуется каждые 15 минут).
"""


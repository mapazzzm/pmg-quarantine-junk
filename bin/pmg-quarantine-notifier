)

PMG_SPOOL        = '/var/spool/pmg'
GEN_TICKET_BIN   = '/usr/local/bin/pmg-quarantine-gen-ticket'


# ---------------------------------------------------------------------------
# PMG авто-авторизационная ссылка
# ---------------------------------------------------------------------------

def get_pmg_quarantine_url(pmail: str, cfg, log) -> str:
    """
    Генерирует ссылку на карантин PMG с RSA-тикетом для автоматической
    авторизации пользователя (тот же механизм, что использует PMG в отчётах).
    При ошибке возвращает обычную ссылку без тикета.
    """
    import subprocess
    try:
        result = subprocess.run(
            [GEN_TICKET_BIN, pmail],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            url = result.stdout.strip()
            if url.startswith('http'):
                return url
        log.warning("gen-ticket failed for %s: %s", pmail, result.stderr.strip())
    except Exception as e:
        log.warning("Cannot generate PMG ticket for %s: %s", pmail, e)

    # Fallback: обычная ссылка без авторизации
    hostname = cfg.get('pmg', 'hostname', fallback='localhost')
    port     = cfg.get('pmg', 'port', fallback='8006')
    return f"https://{hostname}:{port}/quarantine"


# ---------------------------------------------------------------------------
# PMG Database
# ---------------------------------------------------------------------------

def get_pending_quarantine(cfg):
    """Возвращает список новых записей карантина типа 'spam', ещё не уведомлённых."""
    conn = psycopg2.connect(
        host=cfg.get('pmg', 'db_host', fallback='/var/run/postgresql'),
        dbname=cfg.get('pmg', 'db_name', fallback='Proxmox_ruledb'),
        user=cfg.get('pmg', 'db_user', fallback='root'),
        port=cfg.get('pmg', 'db_port', fallback='5432'),
        cursor_factory=psycopg2.extras.RealDictCursor
    )
    cur = conn.cursor()
    cur.execute("""
        SELECT
            C.cid,
            C.rid,
            C.sender,
            C.file,
            C.spamlevel,
            C.header,
            C.time::text AS time_str,
            R.pmail,
            R.receiver,
            R.ticketid,
            R.status,
            'C' || C.cid || 'R' || C.rid || 'T' || R.ticketid AS quarantine_id
        FROM   CMailStore C
        JOIN   CMSReceivers R
               ON  C.cid = R.cmailstore_cid
               AND C.rid = R.cmailstore_rid
        WHERE  C.qtype = 'S'
          AND  R.status = 'N'
        ORDER  BY C.time DESC
    """)
    rows = cur.fetchall()
    cur.close()
    conn.close()
    return rows


# ---------------------------------------------------------------------------
# Парсинг письма из файла карантина
# ---------------------------------------------------------------------------

def decode_mime_header(value: str) -> str:
    if not value:
        return ''
    parts = email.header.decode_header(value)
    decoded = []
    for part, charset in parts:
        if isinstance(part, bytes):
            decoded.append(part.decode(charset or 'utf-8', errors='replace'))
        else:
            decoded.append(part)
    return ' '.join(decoded)


from html.parser import HTMLParser as _HTMLParser


class _HTMLSanitizer(_HTMLParser):
    """
    Санитайзер HTML для вставки тела письма в уведомление.

    Оставляет: всё визуальное форматирование (теги, inline-стили, классы).
    Удаляет целиком (включая содержимое): <style>, <script>, <head>.
    Удаляет тег, но оставляет текст внутри: <a> (ссылки становятся обычным текстом).
    Удаляет без следа: <img>, <link>, <meta>, <base>.
    Нейтрализует: href/src/action/on* атрибуты во всех тегах.
    """

    _SKIP_WITH_CONTENT = frozenset({'style', 'script', 'head'})
    _VOID_REMOVE       = frozenset({'img', 'link', 'meta', 'base', 'input'})
    _STRIP_TAG_ONLY    = frozenset({'a'})          # тег убираем, текст внутри оставляем
    _UNSAFE_ATTRS      = frozenset({               # атрибуты, которые убираем
        'href', 'src', 'action', 'formaction', 'xlink:href',
        'onclick', 'onload', 'onerror', 'onmouseover', 'onmouseout',
        'onfocus', 'onblur', 'onsubmit', 'onchange',
    })

    def __init__(self):
        super().__init__(convert_charrefs=False)
        self._out   = []
        self._depth = 0      # глубина вложенности в _SKIP_WITH_CONTENT

    def handle_starttag(self, tag, attrs):
        if self._depth:
            self._depth += 1
            return
        if tag in self._SKIP_WITH_CONTENT:
            self._depth = 1
            return
        if tag in self._VOID_REMOVE:
            return
        if tag in self._STRIP_TAG_ONLY:
            return   # текст внутри <a>...</a> попадёт через handle_data
        # Безопасный тег — фильтруем атрибуты
        safe = [(k, v) for k, v in attrs
                if k.lower() not in self._UNSAFE_ATTRS]
        if safe:
            attrs_str = ' '.join(
                f'{k}="{v}"' if v is not None else k
                for k, v in safe
            )
            self._out.append(f'<{tag} {attrs_str}>')
        else:
            self._out.append(f'<{tag}>')

    def handle_endtag(self, tag):
        if self._depth:
            self._depth -= 1
            return
        if tag in self._SKIP_WITH_CONTENT | self._VOID_REMOVE | self._STRIP_TAG_ONLY:
            return
        self._out.append(f'</{tag}>')

    def handle_data(self, data):
        if self._depth:
            return
        self._out.append(data)

    def handle_entityref(self, name):
        if not self._depth:
            self._out.append(f'&{name};')

    def handle_charref(self, name):
        if not self._depth:
            self._out.append(f'&#{name};')

    def get_output(self) -> str:
        return ''.join(self._out)


def _sanitize_html(raw_html: str) -> str:
    """
    Возвращает очищенный HTML: форматирование сохранено, ссылки/трекеры удалены.
    Если есть <body>, санитизируем только его содержимое — это надёжнее,
    чем парсить весь документ с <head> и MSO-комментариями.
    """
    # Вырезаем содержимое <body>...</body> если оно есть
    m = re.search(r'<body[^>]*>(.*)</body>', raw_html,
                  flags=re.DOTALL | re.IGNORECASE)
    content = m.group(1) if m else raw_html

    p = _HTMLSanitizer()
    p.feed(content)
    return p.get_output()


def _apply_body_percent(html_body: str, text_body: str, percent: int) -> tuple:
    """
    Обрезает тело письма до заданного процента.
    Для HTML — обрезает по символам с добавлением предупреждения.
    Для plain text — аналогично.
    Возвращает (html_body, text_body).
    """
    if percent <= 0:
        return '', ''
    if percent >= 100:
        return html_body, text_body

    def _truncate(text: str, pct: int) -> tuple[str, bool]:
        limit = max(1, int(len(text) * pct / 100))
        if len(text) <= limit:
            return text, False
        return text[:limit], True

    html_cut, html_was_cut = _truncate(html_body, percent)
    text_cut, text_was_cut = _truncate(text_body, percent)

    if html_was_cut:
        html_cut += (
            f'<p style="color:#999;font-size:11px;font-style:italic;">'
            f'… показано {percent}% текста письма</p>'
        )
    if text_was_cut:
        text_cut += f'\n\n… показано {percent}% текста письма'

    return html_cut, text_cut


def _human_size(n: int) -> str:
    for unit in ('Б', 'КБ', 'МБ', 'ГБ'):
        if n < 1024:
            return f"{n} {unit}"
        n //= 1024
    return f"{n} ГБ"


def parse_quarantine_file(filepath: str) -> dict:
    """
    Разбирает .eml из карантина.
    Возвращает: subject, from, date, body_text, body_html_safe, attachments.
    body_html_safe — текст с <br> вместо переносов строк, HTML-экранирован.
    attachments — список dict(name, mime, size_hr).
    """


    result = {
        'subject':         '(без темы)',
        'from':            '(неизвестно)',
        'date':            '',
        'body_text':       '',       # raw text для text/plain части письма
        'body_html_safe':  '',       # тот же текст, готовый для вставки в HTML
        'attachments':     [],       # [{name, mime, size_hr}, ...]
        'has_html_only':   False,    # True если есть только text/html, нет plain
    }

    try:
        with open(filepath, 'rb') as f:
            msg = email_lib.message_from_bytes(f.read())

        result['subject'] = decode_mime_header(msg.get('Subject', '')) or '(без темы)'
        result['from']    = decode_mime_header(msg.get('From', ''))    or '(неизвестно)'
        result['date']    = msg.get('Date', '')

        # Убираем префикс "SPAM: " добавляемый PMG
        subj = result['subject']
        if subj.upper().startswith('SPAM:'):
            result['subject'] = subj[5:].strip()

        plain_parts = []
        html_parts  = []
        attachments = []

        parts = list(msg.walk()) if msg.is_multipart() else [msg]

        for part in parts:
            ct   = part.get_content_type()
            disp = (part.get('Content-Disposition') or '').lower()
            fname = decode_mime_header(part.get_filename() or '')

            # Вложение — любой part с filename или disposition=attachment
            if fname or 'attachment' in disp:
                payload = part.get_payload(decode=True)
                size = len(payload) if payload else 0
                attachments.append({
                    'name':    fname or '(без имени)',
                    'mime':    ct,
                    'size_hr': _human_size(size),
                })
                continue

            # Тело письма
            if ct == 'text/plain':
                payload = part.get_payload(decode=True)
                if payload:
                    charset = part.get_content_charset('utf-8') or 'utf-8'
                    plain_parts.append(payload.decode(charset, errors='replace'))

            elif ct == 'text/html':
                payload = part.get_payload(decode=True)
                if payload:
                    charset = part.get_content_charset('utf-8') or 'utf-8'
                    html_parts.append(payload.decode(charset, errors='replace'))

        # --- HTML-версия тела (для HTML-части письма уведомления) ---
        if html_parts:
            # Санитизируем: убираем скрипты/стили/ссылки, форматирование сохраняем
            sanitized = _sanitize_html('\n'.join(html_parts))
            # Убираем невидимые spacer-символы
            sanitized = re.sub(r'\u2800+', ' ', sanitized)
            sanitized = re.sub(r'[\u200b-\u200f\ufeff\u034f]+', '', sanitized)
            result['body_html_safe'] = sanitized
            result['has_html_only'] = not bool(plain_parts)
        elif plain_parts:
            # Только plain text → экранируем и заменяем переносы на <br>
            body_plain = '\n'.join(plain_parts).strip()
            result['body_html_safe'] = (
                html_module.escape(body_plain).replace('\n', '<br>\n')
            )

        # --- Plain text-версия (для text/plain части уведомления и fallback) ---
        if plain_parts:
            body = '\n'.join(plain_parts).strip()
        elif html_parts:
            # Из HTML выжимаем текст как запасной вариант
            raw = '\n'.join(html_parts)
            body = re.sub(r'<style[^>]*>.*?</style>', '', raw,
                          flags=re.DOTALL | re.IGNORECASE)
            body = re.sub(r'<script[^>]*>.*?</script>', '', body,
                          flags=re.DOTALL | re.IGNORECASE)
            body = re.sub(r'<(?:br|p|div|tr|li|h[1-6])[^>]*>', '\n', body,
                          flags=re.IGNORECASE)
            body = re.sub(r'<[^>]+>', ' ', body)
            body = re.sub(r'&nbsp;', ' ', body)
            body = re.sub(r'&#\d+;', '', body)
            body = re.sub(r'&[a-zA-Z]+;', '', body)
            body = re.sub(r'\u2800+', ' ', body)
        else:
            body = ''

        body = re.sub(r'[\u00ad\u200b-\u200f\ufeff\u034f]+', '', body)
        body = re.sub(r'[ \t]{4,}', ' ', body)
        body = re.sub(r'\n{3,}', '\n\n', body)
        body = re.sub(r'^[ \t\d]{0,5}$', '', body, flags=re.MULTILINE)
        result['body_text'] = body.strip()

        result['attachments'] = attachments

    except Exception as e:
        result['body_text']      = f'(не удалось прочитать содержимое: {e})'
        result['body_html_safe'] = html_module.escape(result['body_text'])

    return result



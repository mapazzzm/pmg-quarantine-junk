_ATTACHMENTS_BLOCK_TEMPLATE = """\
    <tr>
      <td style="padding:12px 32px 0;">
        <p style="margin:0 0 6px;font-size:12px;color:#999;text-transform:uppercase;
                  letter-spacing:0.5px;">Вложения</p>
        <table width="100%" cellpadding="5" cellspacing="0"
               style="border-collapse:collapse;font-size:13px;">
          {attachment_rows}
        </table>
      </td>
    </tr>"""

_ATTACHMENT_ROW = """\
          <tr style="border-bottom:1px solid #f2f2f2;">
            <td style="color:#555;">&#128206;&nbsp;{name}</td>
            <td style="color:#999;width:130px;white-space:nowrap;">{mime}</td>
            <td style="color:#999;width:70px;white-space:nowrap;text-align:right;">{size_hr}</td>
          </tr>"""

TEXT_TEMPLATE = """\
Письмо задержано фильтром (карантин PMG)
=========================================
От:    {from_addr}
Кому:  {to_addr}
Тема:  {subject}
Дата:  {date}
Оценка спама: {spamlevel}/15
{attachments_text}
Действия:
  Не спам (доставить + добавить в белый список):
    {whitelist_url}

  Спам (удалить + добавить в чёрный список):
    {blacklist_url}

Ссылки действительны {ttl_days} дн. ID: {quarantine_id}

Текст письма:
-------------
{body_text}
"""


def _encode_header(value: str) -> str:
    """RFC 2047: кодирует заголовок если содержит не-ASCII символы."""
    try:
        value.encode('ascii')
        return value          # чисто ASCII — не трогаем
    except UnicodeEncodeError:
        return email.header.Header(value, 'utf-8').encode()


def _encode_address(addr_str: str) -> str:
    """
    RFC 2047: корректно кодирует отображаемое имя в адресе отправителя.
    'Антиспам-сервер <postmaster@example.com>'
    → '=?utf-8?...?= <postmaster@example.com>'
    """
    name, addr = email.utils.parseaddr(addr_str)
    if not name:
        return addr_str
    try:
        name.encode('ascii')
        return addr_str       # имя чисто ASCII — оставляем как есть
    except UnicodeEncodeError:
        encoded_name = email.header.Header(name, 'utf-8').encode()
        return email.utils.formataddr((encoded_name, addr))


def _build_attachments_block(attachments: list) -> str:
    """Возвращает HTML-блок вложений или пустую строку."""

    if not attachments:
        return ''
    rows = '\n'.join(
        _ATTACHMENT_ROW.format(
            name=html_module.escape(a['name']),
            mime=html_module.escape(a['mime']),
            size_hr=a['size_hr'],
        )
        for a in attachments
    )
    return _ATTACHMENTS_BLOCK_TEMPLATE.format(attachment_rows=rows)


def _build_attachments_text(attachments: list) -> str:
    """Возвращает текстовый блок вложений или пустую строку."""
    if not attachments:
        return ''
    lines = ['\nВложения:']
    for a in attachments:
        lines.append(f"  • {a['name']}  ({a['mime']}, {a['size_hr']})")
    return '\n'.join(lines) + '\n'


def build_notification(row: dict, mail_info: dict,
                       whitelist_url: str, blacklist_url: str,
                       pmg_url: str, cfg) -> MIMEMultipart:
    """Собирает MIME-письмо уведомления."""


    ttl_days     = cfg.getint('tokens', 'ttl_days', fallback=7)
    mail_from    = cfg.get('notifications', 'mail_from',
                           fallback='Proxmox Mail Gateway <postmaster@localhost>')
    body_percent = cfg.getint('notifications', 'body_percent', fallback=100)

    attachments    = mail_info.get('attachments', [])
    body_html_safe = mail_info.get('body_html_safe', '') or ''
    body_text      = mail_info.get('body_text', '')      or ''

    # Применяем процент отображения
    body_html_safe, body_text = _apply_body_percent(
        body_html_safe, body_text, body_percent
    )

    body_html_safe = body_html_safe or '(нет текстового содержимого)'
    body_text      = body_text      or '(нет текстового содержимого)'
    body_label     = 'Текст письма (извлечён из HTML)' if mail_info.get('has_html_only') \
                     else 'Текст письма'

    ctx_html = {
        'from_addr':        html_module.escape(mail_info['from']),
        'to_addr':          html_module.escape(row['pmail']),
        'subject':          html_module.escape(mail_info['subject']),
        'date':             html_module.escape(mail_info['date']),
        'spamlevel':        row['spamlevel'],
        'body_html_safe':   body_html_safe,
        'body_label':       body_label,
        'attachments_block': _build_attachments_block(attachments),
        'whitelist_url':    whitelist_url,
        'blacklist_url':    blacklist_url,
        'quarantine_id':    html_module.escape(row['quarantine_id']),
        'ttl_days':         ttl_days,
        'pmg_url':          pmg_url,
    }

    ctx_text = {
        'from_addr':        mail_info['from'],
        'to_addr':          row['pmail'],
        'subject':          mail_info['subject'],
        'date':             mail_info['date'],
        'spamlevel':        row['spamlevel'],
        'body_text':        body_text,
        'attachments_text': _build_attachments_text(attachments),
        'whitelist_url':    whitelist_url,
        'blacklist_url':    blacklist_url,
        'quarantine_id':    row['quarantine_id'],
        'ttl_days':         ttl_days,
        'pmg_url':          pmg_url,
    }

    msg = MIMEMultipart('alternative')
    msg['Subject'] = _encode_header(f"[Карантин] {mail_info['subject']} — от {mail_info['from']}")
    msg['From']    = _encode_address(mail_from)
    msg['To']      = row['pmail']
    msg['X-PMG-Quarantine-ID'] = row['quarantine_id']

    msg.attach(MIMEText(TEXT_TEMPLATE.format(**ctx_text), 'plain', 'utf-8'))
    msg.attach(MIMEText(HTML_TEMPLATE.format(**ctx_html),  'html',  'utf-8'))
    return msg


# ---------------------------------------------------------------------------
# Отправка через SMTP
# ---------------------------------------------------------------------------

def send_notification(msg: MIMEMultipart, recipient: str, cfg, log):
    smtp_host = cfg.get('smtp', 'host', fallback='127.0.0.1')
    smtp_port = cfg.getint('smtp', 'port', fallback=25)
    smtp_user = cfg.get('smtp', 'user', fallback='')
    smtp_pass = cfg.get('smtp', 'password', fallback='')
    smtp_tls  = cfg.getboolean('smtp', 'starttls', fallback=False)

    try:
        with smtplib.SMTP(smtp_host, smtp_port, timeout=30) as s:
            s.ehlo()
            if smtp_tls:
                s.starttls()
                s.ehlo()
            if smtp_user and smtp_pass:
                s.login(smtp_user, smtp_pass)
            s.sendmail(msg['From'], [recipient], msg.as_bytes())
        log.info("Notification sent to %s for %s", recipient, msg['X-PMG-Quarantine-ID'])
    except Exception as e:
        log.error("Failed to send notification to %s: %s", recipient, e)
        raise


# ---------------------------------------------------------------------------
# Основной цикл
# ---------------------------------------------------------------------------

def main():
    cfg = load_config()
    log_level = cfg.get('general', 'log_level', fallback='INFO')
    log = setup_logging('notifier', log_level)

    secret = load_secret()
    ttl_days = cfg.getint('tokens', 'ttl_days', fallback=7)

    action_server_url = cfg.get('action_server', 'public_url').rstrip('/')
    pmg_spool = cfg.get('pmg', 'spool_dir', fallback=PMG_SPOOL)

    state = open_state_db()
    cleanup_expired(state)

    log.info("Scanning PMG quarantine for new entries...")

    try:
        rows = get_pending_quarantine(cfg)
    except Exception as e:
        log.error("Cannot query PMG DB: %s", e)
        sys.exit(1)

    log.info("Found %d pending quarantine entries", len(rows))

    sent = 0
    skipped = 0
    errors = 0

    for row in rows:
        qid = row['quarantine_id']

        if is_notified(state, qid):
            skipped += 1
            continue

        # Путь к файлу в spool
        filepath = os.path.join(pmg_spool, row['file'])
        if not os.path.exists(filepath):
            log.warning("Quarantine file not found, skipping %s: %s", qid, filepath)
            skipped += 1
            continue

        # Парсим письмо
        mail_info = parse_quarantine_file(filepath)

        # Генерируем токены (разные для whitelist и blacklist)
        wl_token = generate_token(qid, row['pmail'], secret, ttl_days)
        bl_token = generate_token(qid + ":bl", row['pmail'], secret, ttl_days)

        whitelist_url = f"{action_server_url}/action?token={wl_token}&action=whitelist"
        blacklist_url = f"{action_server_url}/action?token={bl_token}&action=blacklist"

        # Генерируем авто-авторизационную ссылку на карантин PMG
        pmg_url = get_pmg_quarantine_url(row['pmail'], cfg, log)

        # Собираем и отправляем уведомление
        msg = build_notification(row, mail_info, whitelist_url, blacklist_url,
                                 pmg_url, cfg)
        recipient = row['receiver'] or row['pmail']

        try:
            send_notification(msg, recipient, cfg, log)
            mark_notified(state, qid, row['pmail'], ttl_days)
            sent += 1
        except Exception:
            errors += 1

    state.close()
    log.info("Done. Sent: %d, Skipped: %d, Errors: %d", sent, skipped, errors)

    if errors:
        sys.exit(1)


if __name__ == '__main__':
    main()

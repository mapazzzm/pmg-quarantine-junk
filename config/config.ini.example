# pmg-quarantine-junk — конфигурация
# Скопируйте в /etc/pmg-quarantine-junk/config.ini и заполните параметры.
# Обязательные параметры помечены [REQUIRED].
# ============================================================================

[general]
# Уровень логирования: DEBUG | INFO | WARNING | ERROR
log_level = INFO


# ----------------------------------------------------------------------------
# PMG — параметры подключения к базе данных и spool
# ----------------------------------------------------------------------------
[pmg]
# Hostname PMG (используется в ссылке на карантин в подвале письма)
# [REQUIRED]
hostname = pmg.example.com

# Порт веб-интерфейса PMG
port = 8006

# Параметры PostgreSQL (обычно не нужно менять на стандартной установке PMG)
db_host = /var/run/postgresql
db_name = Proxmox_ruledb
db_user = root
db_port = 5432

# Путь к spool-директории PMG
spool_dir = /var/spool/pmg


# ----------------------------------------------------------------------------
# Токены — срок действия кнопок в письме
# ----------------------------------------------------------------------------
[tokens]
# Количество дней, в течение которых ссылки активны
ttl_days = 7


# ----------------------------------------------------------------------------
# Action server — HTTPS-сервис обработки нажатий кнопок
# ----------------------------------------------------------------------------
[action_server]
# Публичный URL сервера — именно этот адрес вставляется в письма.
# [REQUIRED] — замените на реальный hostname/IP
public_url = https://pmg.example.com:8765

# Адрес и порт, на котором слушает сервис
bind_host = 0.0.0.0
port = 8765

# SSL: включить HTTPS (рекомендуется)
ssl = true

# Пути к SSL-сертификату и ключу.
# Значения по умолчанию — сертификат PMG (Let's Encrypt, обновляется автоматически).
# Если cert и key в одном файле — укажите один путь в оба поля.
ssl_cert = /etc/pmg/pmg-api.pem
ssl_key  = /etc/pmg/pmg-api.pem


# ----------------------------------------------------------------------------
# SMTP — откуда отправляются уведомления пользователям
# ----------------------------------------------------------------------------
[smtp]
# Хост для отправки уведомлений.
# Рекомендуется: IP вашего почтового сервера (Carbonio/Zimbra) порт 25,
# чтобы уведомления НЕ проходили через фильтр PMG.
# [REQUIRED]
host = 192.168.1.100

port = 25

# STARTTLS (обычно не нужно для внутренней сети)
starttls = false

# Аутентификация (оставьте пустым для anon relay из доверенной сети)
user =
password =


# ----------------------------------------------------------------------------
# Уведомления — внешний вид писем
# ----------------------------------------------------------------------------
[notifications]
# Адрес отправителя уведомлений.
# Часть до < — отображаемое имя в почтовом клиенте, можно произвольное.
# [REQUIRED] — замените домен на свой
mail_from = Антиспам-сервер <postmaster@example.com>

# Сколько процентов тела письма из карантина показывать в уведомлении.
# 100 = полный текст (по умолчанию)
# 50  = первая половина
# 0   = не показывать текст вообще (только реквизиты и кнопки)
body_percent = 100

# Минимальный размер тела письма (в символах), при котором работает body_percent.
# Если тело письма короче этого значения — показывается целиком (body_percent игнорируется).
# По умолчанию: 1000
body_min_chars = 1000

# Адреса, для которых уведомления о карантине не отправляются.
# Список через запятую. Регистр не важен. Оставьте пустым для отправки всем.
# Пример: exclude_addresses = noreply@example.com, robot@example.com
exclude_addresses =
